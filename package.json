{
  "name": "pm-csv",
  "version": "2026.7.22",
  "description": "CSV importer and exporter for pm-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unbraind/pm-csv.git"
  },
  "bugs": {
    "url": "https://github.com/unbraind/pm-csv/issues"
  },
  "homepage": "https://github.com/unbraind/pm-csv#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "manifest.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build && npm run build:test && node --test dist-test/*.js",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "audit:prod": "env -u npm_config_allow_scripts npm audit --omit=dev --ignore-scripts",
    "pack:dry-run": "npm pack --dry-run",
    "changelog": "pm-changelog --pm-root .agents/pm --mode prepend --output CHANGELOG.md --release-version-from-package --since-previous-tag --until-release-tag --item-url-base https://github.com/unbraind/pm-csv/blob/main/.agents/pm",
    "changelog:full": "pm-changelog --pm-root .agents/pm --mode replace --output CHANGELOG.md --all-release-tags --release-version-from-package --item-url-base https://github.com/unbraind/pm-csv/blob/main/.agents/pm",
    "changelog:check": "pm-changelog --pm-root .agents/pm --mode prepend --output CHANGELOG.md --release-version-from-package --since-previous-tag --until-release-tag --item-url-base https://github.com/unbraind/pm-csv/blob/main/.agents/pm --check || (pm-changelog --pm-root .agents/pm --mode prepend --output CHANGELOG.md --release-version-from-package --since-previous-tag --until-release-tag --item-url-base https://github.com/unbraind/pm-csv/blob/main/.agents/pm && git diff --exit-code -- CHANGELOG.md)",
    "release:check": "npm run typecheck && npm run build && npm test && npm run audit:prod && npm run pack:dry-run && npm run changelog:check",
    "prepublishOnly": "npm run release:check",
    "release:notes": "pm-changelog --pm-root .agents/pm --stdout --since-previous-tag --until-release-tag --release-version-from-package --item-url-base https://github.com/unbraind/pm-csv/blob/main/.agents/pm --pm-bin ./node_modules/.bin/pm --github-step-summary",
    "prepare": "node scripts/prepare-merge-driver.mjs",
    "merge:install": "pm merge install"
  },
  "peerDependencies": {
    "@unbrained/pm-cli": ">=2026.7.19"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@unbrained/pm-cli": "^2026.7.21",
    "pm-changelog": "^2026.7.10",
    "typescript": "^7.0.2"
  },
  "keywords": [
    "csv",
    "exporter",
    "importer",
    "pm-cli",
    "pm-extension",
    "pm-package"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.18.0"
  },
  "author": "@unbraind",
  "pm": {
    "aliases": [
      "csv"
    ],
    "extensions": [
      "."
    ],
    "catalog": {
      "display_name": "CSV Import/Export",
      "category": "import-export",
      "summary": "CSV importer and exporter for pm-cli",
      "tags": [
        "csv",
        "import",
        "export"
      ],
      "links": {
        "docs": "https://github.com/unbraind/pm-csv#readme",
        "npm": "https://www.npmjs.com/package/pm-csv",
        "repository": "https://github.com/unbraind/pm-csv",
        "report": "https://github.com/unbraind/pm-csv/issues"
      }
    },
    "docs": [
      "README.md",
      "CHANGELOG.md"
    ],
    "examples": [
      "README.md"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
