{"ts":"2026-06-05T14:43:11.807Z","author":"codex","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-csv-69ln"},{"op":"add","path":"/metadata/title","value":"Export --excel/--crlf wrote a lone LF as the final line terminator"},{"op":"add","path":"/metadata/description","value":"buildCsvExport joins records with CRLF for --excel/--crlf, but both write sites appended a hardcoded '\\n', so the FINAL record ended in a lone LF while all others ended CRLF — mixed line endings that break the strict-CRLF promise of --excel (RFC 4180 / Excel)."},{"op":"add","path":"/metadata/type","value":"Issue"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":[]},{"op":"add","path":"/metadata/created_at","value":"2026-06-05T14:43:11.807Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-06-05T14:43:11.807Z"},{"op":"add","path":"/metadata/author","value":"codex"},{"op":"add","path":"/metadata/acceptance_criteria","value":"--excel/--crlf output is uniformly CRLF incl. the trailing terminator (no lone LF); default (LF) export unchanged; build+tests green"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"a5b5eb62ae153b5bcac9347d313a3857afc39c3dabffa83e6b0b5d2af7add91f","message":""}
